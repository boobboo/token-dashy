# Historical usage and costs. These must be admin keys, not ordinary inference keys.
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=

# Local app behavior.
TOKEN_DASHY_BACKEND_PORT=8010
TOKEN_DASHY_FRONTEND_PORT=3010
TOKEN_DASHY_POLL_INTERVAL_SECONDS=300
TOKEN_DASHY_POLL_DAYS=7
TOKEN_DASHY_SEED_DEMO_DATA=true
TOKEN_DASHY_ENABLE_CANARY=false
TOKEN_DASHY_ALERT_TOKEN_THRESHOLD=0.95

# Optional monthly token budgets for historical usage alerts.
# If set, Token Dashy opens an alert when current-month usage reaches the threshold.
TOKEN_DASHY_MONTHLY_TOKEN_BUDGET_OPENAI=
TOKEN_DASHY_MONTHLY_TOKEN_BUDGET_ANTHROPIC=

# ntfy.sh notifications. Set the topic to enable native ntfy alerts.
TOKEN_DASHY_NTFY_SERVER=https://ntfy.sh
TOKEN_DASHY_NTFY_TOPIC=
TOKEN_DASHY_NTFY_TOKEN=

# Optional generic JSON webhook, also called only when a new alert opens.
TOKEN_DASHY_ALERT_WEBHOOK_URL=

# Optional canary requests for observed rate-limit headers.
# Enabling this sends real, tiny generation requests.
OPENAI_API_KEY=
OPENAI_CANARY_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_CANARY_MODEL=

# Frontend browser API target.
# For a remote Docker host, use http://<docker-host-ip-or-dns>:8010, not localhost.
VITE_API_BASE_URL=http://localhost:8010
